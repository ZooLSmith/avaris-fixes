+// PC port: ducking hook for fullscreen cutscene playback (D3DDrv's
+// D3DMoviePlayback). Pauses the engine's music + in-flight SFX so the
+// movie's own audio track is audible. Resumes on un-duck.
+//
+// In-game video TEXTURES (loading screens, UI overlays) deliberately do
+// NOT call this -- they coexist with regular game audio. Only the
+// fullscreen-cutscene path calls duck.
+//
+// Called via GetProcAddress("UCMovieAudioDuck") from D3DDrv so we don't
+// need a static link from D3DDrv to ALAudio.
+//
+// bDucked=1 -> pause everything currently playing.
+// bDucked=0 -> resume.
+
+extern "C" __declspec(dllexport) void UCMovieAudioDuck( int bDucked )
+{
+	if( !GALAudio || !p_alSourcePause || !p_alSourcePlay )
+		return;
+	if( bDucked )
+	{
+		if( GALAudio->MusicSource )
+			p_alSourcePause( GALAudio->MusicSource );
+		for( INT i = 0; i < GALAudio->SourcePool.Num(); i++ )
+		{
+			UALAudioSubsystem::FALSource& s = GALAudio->SourcePool(i);
+			if( s.InUse )
+				p_alSourcePause( s.Source );
+		}
+	}
+	else
+	{
+		if( GALAudio->MusicSource )
+			p_alSourcePlay( GALAudio->MusicSource );
+		for( INT i = 0; i < GALAudio->SourcePool.Num(); i++ )
+		{
+			UALAudioSubsystem::FALSource& s = GALAudio->SourcePool(i);
+			if( s.InUse )
+				p_alSourcePlay( s.Source );
+		}
+	}
+}
+
+// PC port: query the engine's per-category audio volume from outside
+// ALAudio. Used by D3DMoviePlayback to apply the user's "music" slider
+// to its OpenAL source so cutscenes respect the same volume the rest of
+// the music does. Categories are UAudioSubsystem::EVolumeCategory:
+//   0 = music, 1 = sfx, 2 = voice, 3 = voice-chat.
+extern "C" __declspec(dllexport) float UCMovieGetCategoryVolume( int category )
+{
+	if( !GALAudio )
+		return 1.0f;
+	if( category < 0 || category >= UAudioSubsystem::VOLUME_Max )
+		return 1.0f;
+	return GALAudio->GetCategoryVolume( (UAudioSubsystem::EVolumeCategory)category );
+}
