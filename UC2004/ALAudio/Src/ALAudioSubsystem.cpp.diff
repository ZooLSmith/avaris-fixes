+FLOAT UALAudioSubsystem::GetCategoryVolume( EVolumeCategory Category )
+{
+	guard(UALAudioSubsystem::GetCategoryVolume);
+	if( Category < 0 || Category >= UAudioSubsystem::VOLUME_Max )
+		return 0.f;
+	return CategoryVolumes[Category];
+	unguard;
+}
+
+void UALAudioSubsystem::SetCategoryVolume( EVolumeCategory Category, FLOAT NewVolume )
+{
+	guard(UALAudioSubsystem::SetCategoryVolume);
+	if( Category < 0 || Category >= UAudioSubsystem::VOLUME_Max )
+		return;
+	CategoryVolumes[Category] = NewVolume;
+
+	// Music is a single long-lived AL source: PlayMusic stamps AL_GAIN
+	// once at start, so without this re-apply the options slider has no
+	// effect until the next track change. SFX/Voice are stamped at
+	// PlaySoundCue time and live for a fraction of a second, so the next
+	// sound naturally picks up the new value -- nothing to do for them.
+	if( Category == UAudioSubsystem::VOLUME_Music
+		&& MusicSource && p_alSourcef )
+	{
+		p_alSourcef( MusicSource, AL_GAIN, NewVolume );
+	}
+
+	unguard;
+}
+
+INT UALAudioSubsystem::PlayMusic( FString Song, FLOAT FadeInTime )
+{
+	guard(UALAudioSubsystem::PlayMusic);
+
+	// Empty song / "None" stops current music.
+	if( Song.Len() == 0 || Song == TEXT("None") )
+	{
+		StopAllMusic( 0.f );
+		return 0;
+	}
+
+	// Already playing this song -- do nothing, return existing handle.
+	if( CurrentMusicHandle && CurrentMusicSong == Song )
+		return CurrentMusicHandle;
+
+	if( !p_alSourceStop || !p_alGenBuffers )
+		return 0;
+
+	// Stop and free the previous music buffer/source binding.
+	if( CurrentMusicHandle )
+	{
+		p_alSourceStop( MusicSource );
+		p_alSourcei( MusicSource, AL_BUFFER, 0 );
+		if( MusicBuffer )
+		{
+			p_alDeleteBuffers( 1, &MusicBuffer );
+			MusicBuffer = 0;
+		}
+		CurrentMusicHandle = 0;
+		CurrentMusicSong = TEXT("");
+	}
+
+	// Load Music/<Song>.wav. The .wma sibling is ignored on PC -- every
+	// .wma in the tree has a paired .wav.
+	FString WavPath = FString::Printf( TEXT("..\\Music\\%s.wav"), *Song );
+	TArray<BYTE> WavData;
+	if( !appLoadFileToArray( WavData, *WavPath ) )
+	{
+		debugf( NAME_DevSound, TEXT("ALAudio: PlayMusic: wav not found at %s"), *WavPath );
+		return 0;
+	}
+
+	FWaveModInfo Info;
+	if( !Info.ReadWaveInfo( WavData ) )
+	{
+		debugf( NAME_DevSound, TEXT("ALAudio: PlayMusic: ReadWaveInfo failed for %s"), *WavPath );
+		return 0;
+	}
+
+	ALenum Format = AL_NONE;
+	if(      *Info.pChannels == 1 && *Info.pBitsPerSample ==  8 ) Format = AL_FORMAT_MONO8;
+	else if( *Info.pChannels == 1 && *Info.pBitsPerSample == 16 ) Format = AL_FORMAT_MONO16;
+	else if( *Info.pChannels == 2 && *Info.pBitsPerSample ==  8 ) Format = AL_FORMAT_STEREO8;
+	else if( *Info.pChannels == 2 && *Info.pBitsPerSample == 16 ) Format = AL_FORMAT_STEREO16;
+	if( Format == AL_NONE )
+		return 0;
+
+	p_alGenBuffers( 1, &MusicBuffer );
+	p_alBufferData( MusicBuffer, Format, Info.SampleDataStart, Info.SampleDataSize, *Info.pSamplesPerSec );
+	p_alSourcei( MusicSource, AL_BUFFER, (ALint)MusicBuffer );
+	p_alSourcef( MusicSource, AL_PITCH, 1.f );
+	p_alSourcef( MusicSource, AL_GAIN, CategoryVolumes[UAudioSubsystem::VOLUME_Music] );
+	p_alSourcePlay( MusicSource );
+
+	CurrentMusicHandle = NextMusicHandle++;
+	CurrentMusicSong = Song;
+	debugf( NAME_Log, TEXT("ALAudio: PlayMusic '%s' (handle=%d, %d Hz, %d ch)"),
+		*Song, CurrentMusicHandle, *Info.pSamplesPerSec, *Info.pChannels );
+	return CurrentMusicHandle;
+	unguard;
+}
+
+UBOOL UALAudioSubsystem::StopMusic( INT SongHandle, FLOAT FadeOutTime )
+{
+	guard(UALAudioSubsystem::StopMusic);
+	if( SongHandle == 0 || SongHandle != CurrentMusicHandle )
+		return 0;
+	StopAllMusic( FadeOutTime );
+	return 1;
+	unguard;
+}
+
+INT UALAudioSubsystem::StopAllMusic( FLOAT FadeOutTime )
+{
+	guard(UALAudioSubsystem::StopAllMusic);
+	if( !p_alSourceStop || CurrentMusicHandle == 0 )
+		return 0;
+	p_alSourceStop( MusicSource );
+	p_alSourcei( MusicSource, AL_BUFFER, 0 );
+	if( MusicBuffer && p_alDeleteBuffers )
+	{
+		p_alDeleteBuffers( 1, &MusicBuffer );
+		MusicBuffer = 0;
+	}
+	CurrentMusicHandle = 0;
+	CurrentMusicSong = TEXT("");
+	return 0;
+	unguard;
+}
+
+void UALAudioSubsystem::NoteDestroy( AActor* Actor )
+{
+	guard(UALAudioSubsystem::NoteDestroy);
+	if( !Actor ) return;
+	for( INT i = 0; i < SourcePool.Num(); i++ )
+	{
+		if( SourcePool(i).InUse && SourcePool(i).Actor == Actor )
+		{
+			p_alSourceStop( SourcePool(i).Source );
+			SourcePool(i).InUse    = 0;
+			SourcePool(i).bAmbient = 0;
+			SourcePool(i).CueName  = NAME_None;
+			SourcePool(i).Actor    = NULL;
+		}
+	}
+	unguard;
+}
