+void UALAudioSubsystem::NotifyLevelChange()
+{
+	guard(UALAudioSubsystem::NotifyLevelChange);
+	// Every cached SourcePool(i).Actor is a raw pointer into the level
+	// that's about to be torn down. Without stopping them here, Update()
+	// next frame walks the pool, dereferences A->bDeleteMe on freed
+	// memory and GPFs (seen on first menu.unr load).
+	for( INT i = 0; i < SourcePool.Num(); i++ )
+	{
+		if( SourcePool(i).InUse && p_alSourceStop )
+			p_alSourceStop( SourcePool(i).Source );
+		SourcePool(i).InUse    = 0;
+		SourcePool(i).bAmbient = 0;
+		SourcePool(i).CueName  = NAME_None;
+		SourcePool(i).Actor    = NULL;
+	}
+	unguard;
+}
