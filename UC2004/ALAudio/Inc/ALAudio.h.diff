+/*=============================================================================
+	ALAudio.h: Project Avaris OpenAL audio package — public header.
+
+	UC2 PC revival module. Replaces XBoxAudio.XACTAudioSubsystem on PC.
+	Bridges UC2's UAudioSubsystem abstract (cue-driven, FName-keyed) onto
+	OpenAL by parsing Avaris.xap at startup and resolving cues to the raw
+	.wav files in UC2004/SoundData/.
+=============================================================================*/
+
+#ifndef _INC_ALAUDIO
+#define _INC_ALAUDIO
+
+#ifndef ALAUDIO_API
+	#define ALAUDIO_API DLL_IMPORT
+#endif
+
+#ifdef WIN32
+#include <windows.h>
+#endif
+
+#include "Core.h"
+#include "Engine.h"
+#include "UnRender.h"
+
+#include "ALAudioSubsystem.h"
+
+#define AUTO_INITIALIZE_REGISTRANTS_ALAUDIO	\
+	UALAudioSubsystem::StaticClass();
+
+#endif
