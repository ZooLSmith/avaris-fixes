+static void PlayCinematicByOption( const FURL& URL, const TCHAR* OptionName )
+{
+	const TCHAR* MovieName = URL.GetOption( OptionName, NULL );
+	if( !MovieName || !*MovieName )
+		return;
+
+	// UC2 stores movies under Movies/<name>.xmv
+	FString Path = FString::Printf( TEXT("..\\Movies\\%s.xmv"), MovieName );
+
+	GMoviePlaying = TRUE;
+	DecodeMovieFile( *Path );
+	GMoviePlaying = FALSE;
+}
+
+D3DDRV_API void PlayIntroCinematic( const FURL& URL )
+{
+	PlayCinematicByOption( URL, TEXT("StartCinematic") );
+}
+
+D3DDRV_API void PlayOutroCinematic( const FURL& URL )
+{
+	PlayCinematicByOption( URL, TEXT("EndCinematic") );
+}
