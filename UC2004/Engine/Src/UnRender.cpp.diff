+		const INT   _SavedSizeX = Viewport->Canvas->SizeX;
+		const INT   _SavedSizeY = Viewport->Canvas->SizeY;
+		const FLOAT _SavedClipX = Viewport->Canvas->ClipX;
+		const FLOAT _SavedClipY = Viewport->Canvas->ClipY;
+
+		// GUI controller's ResX/ResY drive UGUIComponent::ActualLeft/Top
+		// fractional math; need to override those too. Engine module
+		// can't include GUI/GUIController.h directly, so we reach the
+		// fields by UProperty offset reflection on whichever interaction
+		// is named "GUIController".
+		UObject* _GUI = NULL;
+		UProperty* _ResXProp = NULL;
+		UProperty* _ResYProp = NULL;
+		INT _SavedCtrlResX = 0, _SavedCtrlResY = 0;
+		if( Viewport->InteractionMaster )
+		{
+			for( INT i = 0; i < Viewport->InteractionMaster->GlobalInteractions.Num(); i++ )
+			{
+				UInteraction* It = Viewport->InteractionMaster->GlobalInteractions(i);
+				if( It && appStrcmp(It->GetClass()->GetName(), TEXT("GUIController")) == 0 )
+				{
+					_GUI = It;
+					_ResXProp = FindField<UProperty>( It->GetClass(), TEXT("ResX") );
+					_ResYProp = FindField<UProperty>( It->GetClass(), TEXT("ResY") );
+					break;
+				}
+			}
+		}
+		const FLOAT _HudScale = (FLOAT)_SavedSizeY / 480.f;
+		const INT   _PbW = (INT)(640.f * _HudScale);
+		const INT   _PbH = (INT)(480.f * _HudScale);
+		const INT   _PbX = Max( 0, (_SavedSizeX - _PbW) / 2 );
+		const INT   _PbY = 0;
+
+		Viewport->Canvas->SizeX = 640;
+		Viewport->Canvas->SizeY = 480;
+		Viewport->Canvas->ClipX = 640.f;
+		Viewport->Canvas->ClipY = 480.f;
+		if( _GUI && _ResXProp && _ResYProp )
+		{
+			INT* RX = (INT*)((BYTE*)_GUI + _ResXProp->Offset);
+			INT* RY = (INT*)((BYTE*)_GUI + _ResYProp->Offset);
+			_SavedCtrlResX = *RX;
+			_SavedCtrlResY = *RY;
+			*RX = 640;
+			*RY = 480;
+		}
+
+		// pCanvasUtil's CanvasToScreen projection was built at frame start
+		// against the real backbuffer size (e.g. 1280); script draws in
+		// design-coord space (e.g. x=320) would project to NDC using that
+		// 1280-wide matrix and end up squeezed into the left of the
+		// pillarbox viewport. Flush any in-flight draws against the
+		// original projection, then rebuild the matrix for 640x480 so
+		// design-space coords project to NDC of the logical surface that
+		// the viewport stretches across the pillarbox region.
+		FMatrix _SavedC2S, _SavedS2C;
