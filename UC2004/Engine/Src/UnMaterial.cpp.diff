+static void ResolveMovieMaterialAPI()
+{
+	if (GMovieMatLooked)
+		return;
+	GMovieMatLooked = TRUE;
+
+	HMODULE_LOCAL hD3DDrv = GetModuleHandleA("D3DDrv.dll");
+	if (!hD3DDrv)
+	{
+		debugf(TEXT("[MovieMat] D3DDrv.dll not loaded; movie textures inactive."));
