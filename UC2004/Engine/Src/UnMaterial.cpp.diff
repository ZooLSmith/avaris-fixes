+typedef void (*PFN_UCMovieMaterialCopy)( UMovieMaterial*, void*, int );
+typedef void (*PFN_UCMovieMaterialDispose)( UMovieMaterial* );
+
+static PFN_UCMovieMaterialPump    GMovieMatPump    = NULL;
+static PFN_UCMovieMaterialCopy    GMovieMatCopy    = NULL;
+static PFN_UCMovieMaterialDispose GMovieMatDispose = NULL;
+static UBOOL                      GMovieMatLooked  = FALSE;
