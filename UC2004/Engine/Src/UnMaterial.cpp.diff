+	GMovieMatCopy    = (PFN_UCMovieMaterialCopy)   GetProcAddress(hD3DDrv, "UCMovieMaterialCopy");
+	GMovieMatDispose = (PFN_UCMovieMaterialDispose)GetProcAddress(hD3DDrv, "UCMovieMaterialDispose");
+
+	debugf(TEXT("[MovieMat] D3DDrv movie-material hooks: %s"),
+		(GMovieMatPump && GMovieMatCopy && GMovieMatDispose) ? TEXT("ready") : TEXT("missing"));
+}
